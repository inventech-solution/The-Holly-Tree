{% liquid
  assign logo_count = section.blocks.size
  assign marquee_duration = section.settings.speed | default: 25
  assign visible_logo_count = 0

  for block in section.blocks
    if block.settings.image != blank
      assign visible_logo_count = visible_logo_count | plus: 1
    endif
  endfor
%}

<section id="certifications-logo-slider-{{ section.id }}" class="certifications-logo-slider section section--full-width" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="certifications-logo-slider__box color-{{ section.settings.color_scheme }}">
      {% if section.settings.heading != blank %}
        <h2 class="certifications-logo-slider__heading h2">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if logo_count > 0 and visible_logo_count > 0 %}
        <div class="certifications-logo-slider__viewport" role="region" aria-label="{{ section.settings.heading | default: 'Certifications' | escape }}">
          <div class="certifications-logo-slider__track" style="--marquee-duration: {{ marquee_duration }}s;">
            {% for duplicate in (1..2) %}
              <ul class="certifications-logo-slider__list" role="list" {% if duplicate == 2 %}aria-hidden="true"{% endif %}>
                {% for block in section.blocks %}
                  {% assign logo_alt = block.settings.alt_text | default: section.settings.heading | default: 'Certification logo' %}
                  {% if block.settings.image != blank %}
                    <li class="certifications-logo-slider__item" {% if duplicate == 1 %}{{ block.shopify_attributes }}{% endif %}>
                      <div class="certifications-logo-slider__logo certifications-logo-slider__logo--{{ block.settings.logo_shape }}">
                        {{
                          block.settings.image
                          | image_url: width: 400
                          | image_tag:
                            loading: 'lazy',
                            alt: logo_alt,
                            widths: '90, 180, 200, 400',
                            sizes: '(max-width: 749px) 36vw, 200px',
                            class: 'certifications-logo-slider__image'
                        }}
                      </div>
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>
            {% endfor %}
          </div>
        </div>
      {% else %}
        <p class="certifications-logo-slider__empty">Add logo blocks to show certification logos.</p>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #certifications-logo-slider-{{ section.id }} .certifications-logo-slider__box {
    background: #f6f6f6;
    border-radius: 40px;
    padding: clamp(20px, 3vw, 36px);
    overflow: hidden;
  }

  #certifications-logo-slider-{{ section.id }} .certifications-logo-slider__heading {
    margin: 0 0 clamp(16px, 2vw, 28px);
    text-align: center;
  }

  #certifications-logo-slider-{{ section.id }} .certifications-logo-slider__viewport {
    overflow: hidden;
    width: 100%;
  }

  #certifications-logo-slider-{{ section.id }} .certifications-logo-slider__track {
    display: flex;
    align-items: center;
    gap: clamp(18px, 3vw, 44px);
    width: max-content;
    animation: certifications-marquee-{{ section.id }} var(--marquee-duration) linear infinite;
    will-change: transform;
  }

  #certifications-logo-slider-{{ section.id }} .certifications-logo-slider__list {
    display: flex;
    align-items: center;
    gap: clamp(18px, 3vw, 44px);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #certifications-logo-slider-{{ section.id }} .certifications-logo-slider__item {
    flex: 0 0 auto;
  }

  #certifications-logo-slider-{{ section.id }} .certifications-logo-slider__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: clamp(70px, 10vw, 90px);
    overflow: hidden;
  }

  #certifications-logo-slider-{{ section.id }} .certifications-logo-slider__logo--square {
    width: clamp(70px, 10vw, 90px);
  }

  #certifications-logo-slider-{{ section.id }} .certifications-logo-slider__logo--rectangle {
    width: clamp(150px, 26vw, 200px);
  }

  #certifications-logo-slider-{{ section.id }} .certifications-logo-slider__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  #certifications-logo-slider-{{ section.id }} .certifications-logo-slider__empty {
    margin: 0;
    text-align: center;
  }

  @keyframes certifications-marquee-{{ section.id }} {
    from {
      transform: translate3d(0, 0, 0);
    }

    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #certifications-logo-slider-{{ section.id }} .certifications-logo-slider__track {
      animation: none;
    }
  }
</style>

{% schema %}
{
  "name": "Certification logos",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Certifications"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Scroll speed",
      "default": 25
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "select",
          "id": "logo_shape",
          "label": "Logo size",
          "default": "square",
          "options": [
            {
              "value": "square",
              "label": "Square (90 × 90)"
            },
            {
              "value": "rectangle",
              "label": "Rectangle (200 × 90)"
            }
          ]
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text",
          "default": "Certification logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Certification logos",
      "blocks": [
        {
          "type": "logo"
        },
        {
          "type": "logo"
        },
        {
          "type": "logo"
        }
      ]
    }
  ]
}
{% endschema %}

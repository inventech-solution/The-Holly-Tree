{% liquid
  assign cards_count = section.blocks.size
%}

{{ 'our-process.css' | asset_url | stylesheet_tag }}
<script src="{{ 'scrolltrigger.min.js' | asset_url }}" defer></script>
<script src="{{ 'our-process.js' | asset_url }}" defer></script>

<section class="our-process section-{{ section.id }}" data-section-id="{{ section.id }}" data-our-process-section>
  <div class="our-process__container page-width">
    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <header class="our-process__header">
        {% if section.settings.subheading != blank %}
          <p class="our-process__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="our-process__heading">{{ section.settings.heading }}</h2>
        {% endif %}
      </header>
    {% endif %}

    <div class="our-process__viewport" data-our-process-viewport>
      <div class="our-process__track" data-our-process-track>
        {% for block in section.blocks %}
          <article class="our-process__card" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              <div class="our-process__image-wrapper">
                {{
                  block.settings.image
                  | image_url: width: 700
                  | image_tag:
                    loading: 'lazy',
                    widths: '220, 320, 460, 700',
                    sizes: '(max-width: 767px) 75vw, (max-width: 1200px) 30vw, 22vw',
                    class: 'our-process__image',
                    alt: block.settings.image.alt | escape
                }}
              </div>
            {% endif %}
            {% if block.settings.title != blank %}
              <h3 class="our-process__card-title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <div class="our-process__card-text rte">{{ block.settings.text }}</div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    </div>

    {% if cards_count == 0 %}
      <p class="our-process__empty">Add process cards from the Theme Editor.</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Our Process",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "How we work"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Process"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Process card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Seed Selection"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Describe this process step for your customers.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Process",
      "blocks": [
        { "type": "step" },
        { "type": "step" },
        { "type": "step" },
        { "type": "step" }
      ]
    }
  ]
}
{% endschema %}
